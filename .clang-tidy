Checks: '-*, modernize-use-override, modernize-deprecated-headers, modernize-loop-convert, modernize-use-nullptr, modernize-use-auto, modernize-pass-by-value, modernize-replace-disallow-copy-and-assign-macro, modernize-return-braced-init-list'
HeaderFilterRegex: 'src/.*|examples/.*'
WarningsAsErrors: '*'
