Checks: '-*, modernize-*, -modernize-avoid-c-arrays, -modernize-use-using, -modernize-pass-by-value, -modernize-use-auto, -modernize-return-braced-init-list, -modernize-loop-convert, -modernize-use-trailing-return-type, -modernize-type-traits, -modernize-use-equals-delete'
HeaderFilterRegex: 'src/.*|examples/.*'
WarningsAsErrors: '*'
