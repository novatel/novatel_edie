Checks: '-*, 
cppcoreguidelines-*, 
	-cppcoreguidelines-macro-usage, -cppcoreguidelines-avoid-const-or-ref-data-members, -cppcoreguidelines-avoid-non-const-global-variables, -cppcoreguidelines-special-member-functions, -cppcoreguidelines-owning-memory, -cppcoreguidelines-owning-memory, -cppcoreguidelines-special-member-functions, -cppcoreguidelines-pro-type-vararg, 
bugprone-*, 
	-bugprone-switch-missing-default-case, -bugprone-exception-escape, -bugprone-branch-clone, -bugprone-assignment-in-if-condition, -bugprone-misplaced-widening-cast, -bugprone-exception-escape, -bugprone-reserved-identifier, -bugprone-signed-char-misuse, -bugprone-incorrect-roundings, -bugprone-sizeof-expression, -bugprone-narrowing-conversions, -bugprone-suspicious-include, -bugprone-easily-swappable-parameters, -bugprone-forwarding-reference-overload, -bugprone-macro-parentheses, 
modernize-*, 
	-modernize-avoid-c-arrays, -modernize-use-using, -modernize-pass-by-value, -modernize-use-auto, -modernize-return-braced-init-list, -modernize-loop-convert, -modernize-use-trailing-return-type, -modernize-type-traits, -modernize-use-equals-delete, -modernize-use-nodiscard, -modernize-use-equals-default, -modernize-use-default-member-init, -modernize-concat-nested-namespaces, -modernize-make-unique, -modernize-use-emplace, -modernize-use-transparent-functors, -modernize-raw-string-literal'
HeaderFilterRegex: 'src/.*|examples/.*'
WarningsAsErrors: '*'
